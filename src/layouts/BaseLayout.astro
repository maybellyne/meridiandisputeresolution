---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
}

const { title, description, canonical, schema } = Astro.props;
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- <title>{title}</title> -->
    <title>
  {title
    ? `${title} | Meridian Dispute Resolution`
    : "Meridian Dispute Resolution"}
</title>
    <!-- <meta name="description" content={description} /> -->
    <meta
  name="description"
  content={
    description ||
    "Professional mediation services in Saskatchewan for workplace, commercial, family, and estate disputes. Confidential and neutral conflict resolution."
  }
/>

    <link
  rel="canonical"
  href={canonical || "https://meridiandisputeresolution.ca"}
/>
    
    <meta
  property="og:title"
  content={
    title
      ? `${title} | Meridian Dispute Resolution`
      : "Meridian Dispute Resolution"
  }
/>

<meta
  property="og:description"
  content={
    description ||
    "Professional mediation services in Saskatchewan. Confidential, structured dispute resolution."
  }
/>
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="Meridian Dispute Resolution" />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Meridian Dispute Resolution Inc",
  "url": "https://meridiandisputeresolution.ca",
  "description":
    "Mediation and conflict resolution services for workplace, commercial, family, and estate disputes across Saskatchewan and Canada.",
  "areaServed": {
    "@type": "Place",
    "name": "Saskatchewan, Canada"
  },
  "serviceType": [
    "Workplace Mediation",
    "Family Mediation",
    "Commercial Mediation",
    "Estate Mediation"
  ],
  "sameAs": []
})} />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-name" aria-label="Meridian Dispute Resolution — Home">
          Meridian Dispute Resolution
        </a>

        <nav aria-label="Main navigation">
          <a href="/services" class:list={['nav-link', { active: isActive('/services') }]}>Services</a>
          <a href="/how-it-works" class:list={['nav-link', { active: isActive('/how-it-works') }]}>How It Works</a>
          <a href="/fees" class:list={['nav-link', { active: isActive('/fees') }]}>Fees</a>
          <a href="/faq" class:list={['nav-link', { active: isActive('/faq') }]}>FAQ</a>
          <a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
          <a href="/contact" class="nav-cta">Book Consultation</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-name">Meridian Dispute Resolution Inc</p>
        <p class="footer-note">
          Mediation services across Canada. Based in Saskatchewan.
          Not legal counsel. Not therapy.
        </p>
        <nav aria-label="Footer navigation" class="footer-nav">
          <a href="/services">Services</a>
          <a href="/how-it-works">How It Works</a>
          <a href="/faq">FAQ</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/disclaimer">Disclaimer</a>
        </nav>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Meridian Dispute Resolution Inc. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
