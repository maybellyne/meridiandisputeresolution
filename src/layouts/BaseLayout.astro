---
import '../styles/global.css';
import { url } from '../lib/url';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
}

const SITE_NAME = 'Meridian Dispute Resolution';

const { title, description, canonical, schema } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pageTitle = title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`;

function isActive(path: string) {
  const full = `${base}${path}`;
  if (path === '/') return currentPath === base || currentPath === `${base}/`;
  return currentPath.startsWith(full);
}
---

<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>

    <meta
      name="description"
      content={description ||
        "Professional mediation services in Saskatchewan for workplace, commercial, family, and estate disputes. Confidential and neutral conflict resolution."}
    />

    <link
      rel="canonical"
      href={canonical || "https://meridiandisputeresolution.ca"}
    />

    <meta property="og:title" content={pageTitle} />
    <meta
      property="og:description"
      content={description ||
        "Professional mediation services in Saskatchewan. Confidential, structured dispute resolution."}
    />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content={SITE_NAME} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>

  <body>
    <a href={url('/')} class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="container header-inner">
        <a href={url('/')} class="site-name" aria-label="Meridian Dispute Resolution — Home">
          Meridian Dispute Resolution
        </a>

        <!-- Mobile toggle -->
        <button
          class="nav-toggle"
          aria-label="Toggle navigation"
          aria-expanded="false"
        >
          ☰
        </button>

        <nav class="main-nav" aria-label="Main navigation">
          <a href={url('/services')} class:list={['nav-link', { active: isActive('/services') }]}>Services</a>
          <a href={url('/how-it-works')} class:list={['nav-link', { active: isActive('/how-it-works') }]}>How It Works</a>
          <a href={url('/fees')} class:list={['nav-link', { active: isActive('/fees') }]}>Fees</a>
          <a href={url('/faq')} class:list={['nav-link', { active: isActive('/faq') }]}>FAQ</a>
          <a href={url('/about')} class:list={['nav-link', { active: isActive('/about') }]}>About</a>
          <a href={url('/contact')} class="nav-cta">Book Consultation</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-name">Meridian Dispute Resolution Inc</p>
        <p class="footer-note">
          Mediation services across Canada. Based in Saskatchewan.
          Not legal counsel. Not therapy.
        </p>
        <nav aria-label="Footer navigation" class="footer-nav">
          <a href={url('/services')}>Services</a>
          <a href={url('/how-it-works')}>How It Works</a>
          <a href={url('/faq')}>FAQ</a>
          <a href={url('/about')}>About</a>
          <a href={url('/contact')}>Contact</a>
          <a href={url('/privacy-policy')}>Privacy Policy</a>
          <a href={url('/disclaimer')}>Disclaimer</a>
        </nav>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Meridian Dispute Resolution Inc. All rights reserved.</p>
      </div>
    </footer>

    <!-- Minimal JS toggle -->
    <script>
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.querySelector('.main-nav');

      toggle?.addEventListener('click', () => {
        document.body.classList.toggle('nav-open');

        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
      });
    </script>
  </body>
</html>