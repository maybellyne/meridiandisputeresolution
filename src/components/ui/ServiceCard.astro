---
import { CTA_LEARN_MORE } from '../../lib/cta';

interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<div class="card">
  <h3>{title}</h3>
  <p>{description}</p>
  <a href={href} class="text-link">{CTA_LEARN_MORE} &rarr;</a>
</div>
