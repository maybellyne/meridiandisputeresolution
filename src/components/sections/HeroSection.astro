---
import { CTA_PRIMARY, CTA_HREF } from '../../lib/cta';
import { url } from '../../lib/url';

interface Props {
  title: string;
  subtitle: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  ctaLabel = CTA_PRIMARY,
  ctaHref = CTA_HREF,
} = Astro.props;
---

<section class="hero container">
  <h1>{title}</h1>
  <p class="subtitle">{subtitle}</p>
  <a class="cta-button" href={url(ctaHref)}>{ctaLabel}</a>
</section>