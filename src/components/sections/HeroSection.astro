---
import { CTA_PRIMARY, CTA_HREF } from '../../lib/cta';
import { url } from '../../lib/url';

interface Props {
  title: string;
  subtitle: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  ctaLabel = CTA_PRIMARY,
  ctaHref = CTA_HREF,
} = Astro.props;
---

<section class="hero container">
  <h1>{title}</h1>
  <p class="subtitle">{subtitle}</p>
  <a class="cta-button" href={url(ctaHref)}>{ctaLabel}</a>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-9) 0;
  }

  /* subtle brand depth layer (no layout impact) */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top left,
      rgba(30, 58, 138, 0.06),
      transparent 60%
    );
    pointer-events: none;
  }

  h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--accent);
    max-width: 28ch;
    margin-bottom: var(--space-5);
  }

  .subtitle {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 60ch;
    line-height: 1.8;
    margin-bottom: var(--space-6);
  }

  .cta-button {
    display: inline-block;
  }
</style>