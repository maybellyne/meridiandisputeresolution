---
import { CTA_PRIMARY, CTA_HREF } from '../../lib/cta';

interface Props {
  title: string;
  subtitle: string;
  /** Override the default primary CTA label */
  ctaLabel?: string;
  /** Override the default primary CTA href */
  ctaHref?: string;
}

const {
  title,
  subtitle,
  ctaLabel = CTA_PRIMARY,
  ctaHref = CTA_HREF,
} = Astro.props;
---

<section class="hero container">
  <h1>{title}</h1>
  <p class="subtitle">{subtitle}</p>
  <a class="cta-button" href={ctaHref}>{ctaLabel}</a>
</section>
