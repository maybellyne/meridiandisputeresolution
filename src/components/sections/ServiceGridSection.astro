---
import ServiceCard from '../ui/ServiceCard.astro';
import type { ServiceRecord } from '../../content/services';

interface Props {
  services: ServiceRecord[];
  title?: string;
}

const { services, title } = Astro.props;
---

<section class="container">
  {title && <h2>{title}</h2>}
  <div class="service-grid">
    {services.map(s => (
      <ServiceCard
        title={s.title}
        description={s.description}
        href={`/services/${s.slug}`}
      />
    ))}
  </div>
</section>
