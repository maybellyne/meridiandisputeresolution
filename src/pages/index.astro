---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ServiceGridSection from '../components/sections/ServiceGridSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import { services } from '../content/services';
import { organizationSchema } from '../lib/schema';
import { seo } from '../lib/seo';

const meta = seo(
  'Meridian Dispute Resolution',
  'Neutral mediation services for workplace, family, commercial, and estate disputes. Based in Saskatchewan, serving all of Canada.',
  '/'
);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  schema={organizationSchema}
>

  <!-- HERO -->
  <HeroSection
    title="Resolve Conflict Without Litigation"
    subtitle="Neutral, confidential mediation for workplace, family, commercial, and estate disputes in Saskatchewan and across Canada. Structured process. No side-taking."
  />

  <!-- TRUST -->
  <section class="container trust-strip">
    <div class="trust-grid">
      <div class="trust-item">
        <strong>Neutral</strong>
        <span>Third-party facilitation</span>
      </div>

      <div class="trust-item">
        <strong>Confidential</strong>
        <span>Private resolution process</span>
      </div>

      <div class="trust-item">
        <strong>Canada-wide</strong>
        <span>Remote & in-person sessions</span>
      </div>

      <div class="trust-item">
        <strong>Structured</strong>
        <span>Defined mediation framework</span>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <ServiceGridSection
    services={services}
    title="Areas of Practice"
  />

  <!-- PROCESS -->
  <section class="container process-note">
    <h2>How the Process Works</h2>

    <ol class="process-list">
      <li>
        <strong>Initial consultation</strong>
        <span>Free 30-minute assessment to determine suitability</span>
      </li>

      <li>
        <strong>Mediation sessions</strong>
        <span>Structured individual or joint sessions facilitated neutrally</span>
      </li>

      <li>
        <strong>Resolution</strong>
        <span>Agreement documentation or facilitated closure</span>
      </li>
    </ol>
  </section>

  <!-- CTA -->
  <CTASection
    title="Start with a Confidential Consultation"
    body="No obligation. No pressure. A 30-minute assessment to determine whether mediation is appropriate for your situation."
  />

</BaseLayout>

<style>
/* TRUST */
.trust-strip {
  margin-top: var(--space-6);
  margin-bottom: var(--space-7);
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-5);
  padding: var(--space-5);
}

.trust-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.trust-item strong {
  color: var(--accent);
  font-weight: 700;
}

.trust-item span {
  color: var(--text-muted);
  font-size: 0.95rem;
  line-height: 1.4;
}

/* PROCESS */
.process-note {
  margin-top: var(--space-8);
  margin-bottom: var(--space-8);
}

.process-note h2 {
  margin-bottom: var(--space-5);
}

.process-list {
  list-style: none;
  padding: 0;
  display: grid;
  gap: var(--space-5);
}

.process-list li {
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.process-list strong {
  color: var(--accent);
  font-weight: 700;
}

.process-list span {
  color: var(--text-muted);
  line-height: 1.6;
}

/* RESPONSIVE */
@media (max-width: 900px) {
  .trust-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .trust-grid {
    grid-template-columns: 1fr;
  }
}
</style>