---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seo } from '../lib/seo';

const meta = seo(
  'Disclaimer',
  'Meridian Dispute Resolution Inc is not a law firm and does not provide legal advice.',
  '/disclaimer'
);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
>
  <section class="container-narrow">
    <h1>Disclaimer</h1>

    <h2>Not Legal Advice</h2>
    <p>
      Meridian Dispute Resolution Inc is not a law firm and does not provide
      legal advice. Nothing on this website or communicated during a mediation
      engagement constitutes legal advice or creates a solicitor-client
      relationship.
    </p>
    <p>
      Parties are encouraged to obtain independent legal advice before, during,
      and after the mediation process — particularly before signing any
      agreement reached through mediation.
    </p>

    <h2>Not Therapy</h2>
    <p>
      Mediation is a structured dispute resolution process. It is not a
      therapeutic service and is not a substitute for mental health support.
      If you or another party require mental health support, we encourage
      you to seek appropriate professional assistance.
    </p>

    <h2>No Guarantee of Outcome</h2>
    <p>
      Meridian does not guarantee that any mediation engagement will result
      in a resolution. Outcomes depend on the willingness of all parties to
      engage in good faith. Where mediation does not result in agreement,
      all parties retain their legal rights in full.
    </p>

    <h2>Accuracy of Information</h2>
    <p>
      While Meridian endeavours to keep information on this website accurate
      and current, we make no representations or warranties about the
      completeness or accuracy of any content. This website is for general
      informational purposes only.
    </p>
  </section>
</BaseLayout>
